    {
      "name": "Owner",
      "item": [
        {
          "name": "Create Workplace",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) pm.collectionVariables.set('workplaceId', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "{{apiKeyHeaderName}}",
                "value": "{{apiKeyValue}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtOwner}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sample Store\",\n  \"address\": \"Seoul\"\n}"
            },
            "url": "{{baseUrl}}/api/owner/workplaces"
          }
        },
        {
          "name": "Get Invite Code",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.workplaceId) pm.collectionVariables.set('workplaceId', json.workplaceId);",
                  "  if (json.inviteCode) pm.collectionVariables.set('inviteCode', json.inviteCode);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "{{apiKeyHeaderName}}",
                "value": "{{apiKeyValue}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtOwner}}"
              }
            ],
            "url": "{{baseUrl}}/api/owner/workplaces/{{workplaceId}}/invite-code"
          }
        },
        {
          "name": "Today Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "{{apiKeyHeaderName}}",
                "value": "{{apiKeyValue}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtOwner}}"
              }
            ],
            "url": "{{baseUrl}}/api/owner/workplaces/{{workplaceId}}/dashboard/today"
          }
        },
        {
          "name": "Staff Attendance Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "{{apiKeyHeaderName}}",
                "value": "{{apiKeyValue}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtOwner}}"
              }
            ],
            "url": "{{baseUrl}}/api/owner/workplaces/{{workplaceId}}/attendance-records?fromDate={{fromDate}}&toDate={{toDate}}"
          }
        },
        {
          "name": "Expected Wage Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "{{apiKeyHeaderName}}",
                "value": "{{apiKeyValue}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtOwner}}"
              }
            ],
            "url": "{{baseUrl}}/api/owner/workplaces/{{workplaceId}}/wages/expected?fromDate={{fromDate}}&toDate={{toDate}}"
          }
        },
        {
          "name": "Approve Attendance Request",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "{{apiKeyHeaderName}}",
                "value": "{{apiKeyValue}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtOwner}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\"\n}"
            },
            "url": "{{baseUrl}}/api/owner/attendance-requests/{{requestId}}"
          }
        }
      ]
    },
