          "name": "Sign Up Owner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "{{apiKeyHeaderName}}",
                "value": "{{apiKeyValue}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loginId\": \"owner01\",\n  \"password\": \"password1234\",\n  \"name\": \"Owner User\",\n  \"userType\": \"OWNER\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signup"
