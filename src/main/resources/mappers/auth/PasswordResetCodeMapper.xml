<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.api.alba.mapper.auth.PasswordResetCodeMapper">

    <resultMap id="passwordResetCodeMap" type="com.api.alba.domain.auth.PasswordResetCode">
        <id property="id" column="ID"/>
        <result property="userId" column="USER_ID"/>
        <result property="email" column="EMAIL"/>
        <result property="code" column="CODE"/>
        <result property="expiresAt" column="EXPIRES_AT"/>
        <result property="usedAt" column="USED_AT"/>
        <result property="createdAt" column="CREATED_AT"/>
    </resultMap>

    <insert id="insert" parameterType="com.api.alba.domain.auth.PasswordResetCode" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO PASSWORD_RESET_CODES (USER_ID, EMAIL, CODE, EXPIRES_AT, USED_AT)
        VALUES (#{userId}, #{email}, #{code}, #{expiresAt}, #{usedAt})
    </insert>

    <delete id="deleteByUserId">
        DELETE FROM PASSWORD_RESET_CODES
        WHERE USER_ID = #{userId}
    </delete>

    <select id="findValidCode" resultMap="passwordResetCodeMap">
        SELECT ID, USER_ID, EMAIL, CODE, EXPIRES_AT, USED_AT, CREATED_AT
        FROM PASSWORD_RESET_CODES
        WHERE USER_ID = #{userId}
          AND CODE = #{code}
          AND USED_AT IS NULL
          AND EXPIRES_AT >= #{now}
        ORDER BY ID DESC
        LIMIT 1
    </select>

    <update id="markUsed">
        UPDATE PASSWORD_RESET_CODES
        SET USED_AT = #{usedAt}
        WHERE ID = #{id}
    </update>

</mapper>
