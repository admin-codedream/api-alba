<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.api.alba.mapper.owner.PayslipDeductionMapper">

    <resultMap id="payslipDeductionMap" type="com.api.alba.domain.owner.PayslipDeduction">
        <id property="id" column="ID"/>
        <result property="payslipId" column="PAYSLIP_ID"/>
        <result property="deductionType" column="DEDUCTION_TYPE"/>
        <result property="name" column="NAME"/>
        <result property="amount" column="AMOUNT"/>
        <result property="note" column="NOTE"/>
        <result property="displayOrder" column="DISPLAY_ORDER"/>
        <result property="appliedRate" column="APPLIED_RATE"/>
        <result property="appliedBaseAmount" column="APPLIED_BASE_AMOUNT"/>
    </resultMap>

    <insert id="insert" parameterType="com.api.alba.domain.owner.PayslipDeduction" useGeneratedKeys="true" keyProperty="id">
        /* insert */
        INSERT INTO PAYSLIP_DEDUCTIONS (PAYSLIP_ID, DEDUCTION_TYPE, NAME, AMOUNT, NOTE, DISPLAY_ORDER, APPLIED_RATE, APPLIED_BASE_AMOUNT)
        VALUES (#{payslipId}, #{deductionType}, #{name}, #{amount}, #{note}, #{displayOrder}, #{appliedRate}, #{appliedBaseAmount})
    </insert>

    <select id="findByPayslipId" resultMap="payslipDeductionMap">
        /* findByPayslipId */
        SELECT ID, PAYSLIP_ID, DEDUCTION_TYPE, NAME, AMOUNT, NOTE, DISPLAY_ORDER, APPLIED_RATE, APPLIED_BASE_AMOUNT
        FROM PAYSLIP_DEDUCTIONS
        WHERE PAYSLIP_ID = #{payslipId}
        ORDER BY DISPLAY_ORDER ASC, ID ASC
    </select>

    <delete id="deleteByPayslipId">
        DELETE FROM PAYSLIP_DEDUCTIONS
        WHERE PAYSLIP_ID = #{payslipId}
    </delete>

</mapper>