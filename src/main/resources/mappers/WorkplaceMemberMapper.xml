<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.api.alba.mapper.WorkplaceMemberMapper">

    <resultMap id="workplaceMemberMap" type="com.api.alba.domain.WorkplaceMember">
        <id property="id" column="ID"/>
        <result property="workplaceId" column="WORKPLACE_ID"/>
        <result property="userId" column="USER_ID"/>
        <result property="role" column="ROLE"/>
        <result property="hourlyWage" column="HOURLY_WAGE"/>
        <result property="status" column="STATUS"/>
    </resultMap>

    <select id="findActiveMember" resultMap="workplaceMemberMap">
        SELECT ID, WORKPLACE_ID, USER_ID, ROLE, HOURLY_WAGE, STATUS
        FROM WORKPLACE_MEMBERS
        WHERE WORKPLACE_ID = #{workplaceId}
          AND USER_ID = #{userId}
          AND STATUS = 'ACTIVE'
    </select>

</mapper>
